# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.

# Anthropic (required for default pipeline operation)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (required only when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Azure OpenAI (required only when LLM_PROVIDER=azure)
# Use this instead of LLM_PROVIDER=openai when your OpenAI key is provisioned
# through an Azure AI Foundry / Azure OpenAI resource rather than
# platform.openai.com directly.
#
# ENDPOINT must be the Foundry "project endpoint" ending in /openai/v1
# (Azure's unified, OpenAI-compatible API surface). No api-version needed —
# that only applies to the older https://<resource>.openai.azure.com surface.
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.services.ai.azure.com/openai/v1
# Azure addresses models by deployment name (set when you create the
# deployment in Azure AI Foundry), not by OpenAI model ID — though they
# often match, as with gpt-5.4 below.
AZURE_OPENAI_DEPLOYMENT=<your-deployment-name>

# Provider selection — default is "anthropic"
# "openai" routes through platform.openai.com directly (GPT-5.4)
# "azure" routes through an Azure OpenAI resource (see AZURE_OPENAI_* above)
LLM_PROVIDER=anthropic

# Force a specific model ID regardless of LLM_PROVIDER (optional)
# Overrides the internal model map. Leave blank to use the map.
LLM_MODEL_OVERRIDE=
